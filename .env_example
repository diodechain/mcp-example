# Place as `.env` in the project root. Python always reads this file when it exists.
# Precedence: code defaults → this file → systemd/launchd/shell env (last wins).
# If `.env` is missing or a line is omitted, defaults match the commented examples below.
# Diode is not configured in config.yml.

# -----------------------------------------------------------------------------
# Join mode (optional)
# -----------------------------------------------------------------------------
# If set, the Diode CLI runs `join <address>` instead of `publish`.
# Leave unset to use publish mode with the variables below.
# DIODE_JOIN_ADDRESS=0xYourPerimeterOrFleetAddress

# -----------------------------------------------------------------------------
# Publish mode (when DIODE_JOIN_ADDRESS is not set)
# -----------------------------------------------------------------------------
# Who can reach the published service on the Diode Network:
#   public    — anyone (default)
#   protected — only identities in the same Fleet Contract (see Diode fleet docs)
#   private   — only identities listed in DIODE_PUBLISH_ALLOWLIST (required)
# DIODE_PUBLISH_SCOPE=public

# External perimeter port on <client>.diode.link:<port>/mcp (maps to your local MCP port).
# DIODE_PUBLISH_PORT=8080

# Required when DIODE_PUBLISH_SCOPE=private: comma-separated allowlist (no spaces needed).
# Examples mix Diode hex addresses, device names, and BNS names:
# DIODE_PUBLISH_ALLOWLIST=0xb6a70432a8bbbcb9ce019c9a9c82fd0f651be123,drive-8xw0olv627tmgkbcurm5,my-bns-domain
